# ---------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit a real .env.
# ---------------------------------------------------------------------------

# Postgres connection. For local Docker Compose the app service overrides this
# to point at the `db` container; for running `prisma migrate`/`dev` on the host
# against the compose DB, use localhost:
DATABASE_URL="postgresql://estate:estate@localhost:5432/estate?schema=public"

# Auth.js session signing secret (REQUIRED). Generate one with:
#   npx auth secret       (writes AUTH_SECRET for you)
# or: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"

# Field-level encryption key for sensitive data at rest (REQUIRED).
# Must be base64 of exactly 32 bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="replace-me-base64-32-bytes"

# Claude API — powers the conversational explanation layer ONLY.
ANTHROPIC_API_KEY="sk-ant-..."
# Optional model override (defaults to claude-opus-4-8):
# ANTHROPIC_MODEL="claude-opus-4-8"

# Plaid (OPTIONAL). If unset, the app uses a built-in MOCK adapter so account
# linking works without credentials. Add these to use the live sandbox:
# PLAID_CLIENT_ID=""
# PLAID_SECRET=""
# PLAID_ENV="sandbox"
