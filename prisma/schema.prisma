// Financial "case file" data model.
//
// Design notes:
//  - Sensitive values (account numbers, SSNs if ever collected) are stored
//    ENCRYPTED at rest in `*Enc` string columns via src/lib/crypto. The raw
//    values are never persisted in plaintext and never logged.
//  - Auth uses Auth.js with the Credentials provider + JWT sessions, so we do
//    NOT use Auth.js's own Account/Session tables (which would also collide by
//    name with our financial `Account` model). The `User.passwordHash` column
//    backs credential login.
//  - Enum string values intentionally match the rules-engine string unions in
//    src/lib/rules/types.ts so snapshots map cleanly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String?

  // Null until the first-run onboarding tour is finished OR skipped. Once set,
  // the tour no longer auto-opens (users can still replay it from Settings).
  onboardingCompletedAt DateTime?

  profile       Profile?
  familyMembers FamilyMember[]
  lifeEvents    LifeEvent[]
  accounts      Account[]
  flags         Flag[]
  chatMessages  ChatMessage[]
  qcdEntries    QcdEntry[]
  estateDocuments   EstateDocument[]
  goals             Goal[]
  checklistItems    ChecklistItemState[]
  educationAccounts EducationAccount[]
  subscription      Subscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id               String        @id @default(cuid())
  userId           String        @unique
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName         String?
  stateOfResidence String?
  dateOfBirth      DateTime?
  maritalStatus    MaritalStatus @default(SINGLE)
  currentSpouseName String?
  dependentsCount  Int           @default(0)
  // The next scheduled quarterly review/check-in date.
  nextReviewDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FamilyMember {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  relationship FamilyRelationship
  fullName     String
  dateOfBirth  DateTime?
  // For SPOUSE / FORMER_SPOUSE rows: relevant key dates.
  marriageDate DateTime?
  divorceDate  DateTime?
  notes        String?

  createdAt DateTime @default(now())
}

model LifeEvent {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              LifeEventType
  eventDate         DateTime
  description       String?
  relatedPersonName String?

  createdAt DateTime @default(now())
}

model Account {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  source          AccountSource @default(MANUAL)
  // Plaid linkage (sandbox). Access tokens are stored encrypted on PlaidItem.
  plaidItemId     String?
  plaidAccountId  String?
  institutionName String?
  accountType     AccountType   @default(OTHER)
  nickname        String
  balance         Decimal?      @db.Decimal(18, 2)
  currency        String        @default("USD")
  balanceAsOf     DateTime?

  // Encrypted at rest. Plaid & most custodians do NOT expose account numbers or
  // beneficiaries; these are typically manual entry.
  accountNumberEnc String?

  // Beneficiary metadata (usually manual — custodians rarely expose it).
  beneficiaryPrimaryName         String?
  beneficiaryPrimaryRelationship BeneficiaryRelationship?
  beneficiaryContingentName      String?
  beneficiaryLastConfirmed       DateTime?

  inheritedIraDetail InheritedIraDetail?
  flags              Flag[]
  qcdEntries         QcdEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InheritedIraDetail {
  id                     String                       @id @default(cuid())
  accountId              String                       @unique
  account                Account                      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  originalOwnerName      String?
  originalOwnerDateOfBirth DateTime?
  originalOwnerDateOfDeath DateTime
  beneficiaryClass       InheritedIraBeneficiaryClass
  beneficiaryDateOfBirth DateTime?
  currentYearDistribution Decimal?                    @db.Decimal(18, 2)
  priorYearEndBalance    Decimal?                     @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A Plaid Item (one linked institution). Access token stored ENCRYPTED.
model PlaidItem {
  id             String   @id @default(cuid())
  userId         String
  itemId         String   @unique
  accessTokenEnc String
  institutionName String?
  createdAt      DateTime @default(now())
}

model Flag {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId      String?
  account        Account?   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ruleId         RuleId
  code           String
  severity       Severity
  title          String
  detail         String
  dataJson       Json?
  status         FlagStatus @default(OPEN)
  dismissedReason String?

  // Stable per-user key ("<accountId|profile>:<code>") so re-evaluation updates
  // the same flag and preserves resolved/dismissed status.
  dedupeKey String

  firstDetectedAt DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  resolvedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, dedupeKey])
  @@index([userId, status])
}

model ChatMessage {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    ChatRole
  content String
  createdAt DateTime @default(now())
}

// Qualified Charitable Distribution logged by an account owner (age 70½+) from
// an IRA during a tax year. Additive to the model; used by the planning-tools
// QCD tracker only — the compliance rules engine does not read or write it.
model QcdEntry {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount           Decimal  @db.Decimal(18, 2)
  distributionDate DateTime
  charityName      String?
  taxYear          Int
  notes            String?

  createdAt DateTime @default(now())

  @@index([userId, taxYear])
}

// --- Phase 2–4 planning trackers (additive; used only by planning tools) ---

model EstateDocument {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  docType         EstateDocType
  exists          Boolean       @default(false)
  lastReviewed    DateTime?
  attorneyName    String?
  attorneyContact String?
  storageLocation String?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, docType])
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  targetAmount Decimal   @db.Decimal(18, 2)
  targetDate   DateTime?
  currentSaved Decimal   @default(0) @db.Decimal(18, 2)
  startDate    DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChecklistItemState {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklistKey String
  itemKey      String
  checked      Boolean  @default(false)

  updatedAt DateTime @updatedAt

  @@unique([userId, checklistKey, itemKey])
}

model EducationAccount {
  id                 String               @id @default(cuid())
  userId             String
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountType        EducationAccountType @default(PLAN_529)
  institutionName    String?
  beneficiaryName    String?
  balance            Decimal?             @db.Decimal(18, 2)
  annualContribution Decimal?             @db.Decimal(18, 2)
  stateOfPlan        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EstateDocType {
  WILL
  REVOCABLE_TRUST
  IRREVOCABLE_TRUST
  FINANCIAL_POA
  HEALTHCARE_POA
}

enum EducationAccountType {
  PLAN_529
  COVERDELL
}

// --- Billing / subscription (additive) ---
// A user's tier is derived by src/lib/billing/entitlements.ts. No row = FREE.
// The Stripe webhook is the single source of truth that writes this row.
model Subscription {
  id                   String              @id @default(cuid())
  userId               String              @unique
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?             @unique
  stripeSubscriptionId String?             @unique
  tier                 SubscriptionTier    @default(FREE)
  billingInterval      BillingInterval?
  status               SubscriptionStatus  @default(ACTIVE)
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionTier {
  FREE
  PLUS
  PRO
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

// --- Waitlist (additive; unrelated to auth/users) ---
model WaitlistSignup {
  id             String    @id @default(cuid())
  email          String    @unique
  token          String    @unique
  confirmedAt    DateTime?
  tokenExpiresAt DateTime
  createdAt      DateTime  @default(now())
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
}

enum FamilyRelationship {
  SPOUSE
  FORMER_SPOUSE
  CHILD
  DEPENDENT
  PARENT
  SIBLING
  OTHER
}

enum LifeEventType {
  MARRIAGE
  DIVORCE
  DEATH_OF_RELATIVE
  INHERITANCE
  BIRTH
  OTHER
}

enum AccountSource {
  PLAID
  MANUAL
}

enum AccountType {
  TRADITIONAL_IRA
  ROTH_IRA
  INHERITED_IRA
  PLAN_401K
  PLAN_403B
  HSA
  LIFE_INSURANCE
  ANNUITY
  BROKERAGE
  BANK_CHECKING
  BANK_SAVINGS
  OTHER
}

enum BeneficiaryRelationship {
  SPOUSE
  FORMER_SPOUSE
  CHILD
  GRANDCHILD
  PARENT
  SIBLING
  TRUST
  ESTATE
  CHARITY
  OTHER
  NONE
}

enum InheritedIraBeneficiaryClass {
  SPOUSE
  MINOR_CHILD_OF_OWNER
  DISABLED
  CHRONICALLY_ILL
  NOT_MORE_THAN_10_YEARS_YOUNGER
  NON_ELIGIBLE
  NON_PERSON
}

enum RuleId {
  INHERITED_IRA_10YR
  BENEFICIARY_MISMATCH
}

enum Severity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FlagStatus {
  OPEN
  DISMISSED
  RESOLVED
}

enum ChatRole {
  USER
  ASSISTANT
}
